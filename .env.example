# Server
PORT=3001

# Session (mindestens 32 zufällige Zeichen)
SESSION_SECRET=ZUFAELLIGER_LANGER_STRING_MINDESTENS_32_ZEICHEN

# Admin Passwort (bcrypt Hash, generieren mit: node -e "const b=require('bcrypt');b.hash('DEIN_PASSWORT',12).then(console.log)")
ADMIN_PASSWORD_HASH=BCRYPT_HASH_DES_PASSWORTS

# NocoDB
NOCODB_API_URL=https://nocodb.antoniabutze.de
NOCODB_API_TOKEN=NOCODB_API_TOKEN
NOCODB_TABLE_ID=NOCODB_TABLE_ID_AUS_DER_URL

# n8n Webhook
N8N_WEBHOOK_ENTSCHEIDUNG=https://n8n.antoniabutze.de/webhook/recruiting-entscheidung

# Azure OpenAI
AZURE_OPENAI_API_KEY=AZURE_API_KEY
AZURE_OPENAI_ENDPOINT=https://DEIN_ENDPOINT.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Nextcloud
NEXTCLOUD_BASE_URL=https://nextcloud.antoniabutze.de
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=NEXTCLOUD_PASSWORT

# Produktion
NODE_ENV=production
ALLOWED_ORIGIN=https://recruiting.antoniabutze.de
